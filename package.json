{
  "name": "batch-payment-app",
  "productName": "PayBatch",
  "version": "1.2.1",
  "description": "PayBatch — a local, offline desktop app to build and export your bank's bulk-payment files (Bacs, Bacs Standard 18, ISO 20022, SEPA), with UK modulus checking. Supports Santander, HSBC, Barclays, Lloyds, NatWest and more. Replaces the clunky Excel process.",
  "main": "main.js",
  "author": "Victor Saly <info@victorsaly.com>",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/victorsaly/batch-payment-app#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/victorsaly/batch-payment-app.git"
  },
  "bugs": {
    "url": "https://github.com/victorsaly/batch-payment-app/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "concurrently -k -n vite,electron -c cyan,magenta \"vite\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "preview:renderer": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node test/run.js",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder",
    "dist:mac": "npm run build:renderer && electron-builder --mac",
    "dist:win": "npm run build:renderer && electron-builder --win",
    "dist:linux": "npm run build:renderer && electron-builder --linux",
    "release": "npm run build:renderer && electron-builder --publish always"
  },
  "build": {
    "appId": "com.victorsaly.paybatch",
    "productName": "PayBatch",
    "copyright": "Copyright © 2026 Victor Saly",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "!src/renderer-src/**",
      "build/icon.png",
      "CHANGELOG.md"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "victorsaly",
        "repo": "batch-payment-app"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.finance",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "PayBatch"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Finance",
      "maintainer": "Victor Saly <info@victorsaly.com>"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-select": "^2.3.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
